async function check1155Access(){

const provider =
new ethers.providers.Web3Provider(window.ethereum);

const signer = provider.getSigner();

const user =
await signer.getAddress();

const contract =
new ethers.Contract(
"ERC1155_CONTRACT",
ERC1155_ABI,
provider
);

// Required token ID
const tokenId = 1;

const balance =
await contract.balanceOf(user, tokenId);

if(balance > 0){

    console.log("ACCESS GRANTED");

    return true;

} else {

    alert("ERC-1155 token required");

    return false;
}

}
